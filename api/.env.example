# Copy this file to .env and fill in real values.
# .env is gitignored — do not commit real secrets.

# Bearer token clients must send on every /api/v1/* request.
API_KEY=choose-a-long-random-string

# FMCSA QCMobile API key — get yours at https://mobile.fmcsa.dot.gov/QCDevsite/docs/apiAccess
FMCSA_WEB_KEY=your-fmcsa-web-key-here

# SQLAlchemy connection string. SQLite for local dev; change for prod.
DATABASE_URL=sqlite:///./dev.db
